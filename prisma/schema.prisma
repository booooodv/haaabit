generator client {
  provider = "prisma-client"
  output   = "../apps/api/src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  isAdmin       Boolean   @default(false)
  timezone      String    @default("UTC")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  apiToken      ApiToken?
  habits        Habit[]
}

model AppSettings {
  id                  String   @id
  registrationEnabled Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ApiToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String   @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@unique([identifier, value])
}

model Habit {
  id             String        @id @default(cuid())
  userId         String
  kind           String
  name           String
  description    String?
  category       String?
  frequencyType  String
  frequencyCount Int?
  targetValue    Int?
  unit           String?
  startDate      String
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekdays       HabitWeekday[]
  dayStates      HabitDayState[]
  mutations      CheckInMutation[]

  @@index([userId, isActive])
  @@index([frequencyType])
}

model HabitWeekday {
  id      String @id @default(cuid())
  habitId String
  day     String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, day])
  @@index([day])
}

model HabitDayState {
  id         String            @id @default(cuid())
  habitId     String
  dateKey     String
  value       Int?
  completed   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  habit       Habit             @relation(fields: [habitId], references: [id], onDelete: Cascade)
  mutations   CheckInMutation[]

  @@unique([habitId, dateKey])
  @@index([dateKey])
  @@index([habitId, completed, dateKey])
}

model CheckInMutation {
  id                String        @id @default(cuid())
  habitId            String
  dayStateId         String
  dateKey            String
  type               String
  source             String
  note               String?
  previousValue      Int?
  nextValue          Int?
  previousCompleted  Boolean
  nextCompleted      Boolean
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  habit              Habit         @relation(fields: [habitId], references: [id], onDelete: Cascade)
  dayState           HabitDayState @relation(fields: [dayStateId], references: [id], onDelete: Cascade)

  @@index([habitId, dateKey, createdAt])
  @@index([dayStateId, createdAt])
}
